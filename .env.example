# GoHighLevel lead sync — location-scoped Private Integration Token + location ID.
# On form submit the lead is upserted as a GHL contact tagged with GHL_WEBSITE_LEAD_TAGS
# (comma-separated). Those tags are the trigger for the auto-text automation.
# Leave GHL_API_TOKEN/GHL_LOCATION_ID blank to disable the sync (email still sends).
GHL_API_TOKEN=
GHL_LOCATION_ID=
GHL_WEBSITE_LEAD_TAGS=website-lead,website-form
